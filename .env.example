# Sigma Memory Agent — Environment Variables
# Copy this to .env and fill in your credentials

# Required: Qwen Cloud API Key (from home.qwencloud.com)
DASHSCOPE_API_KEY=sk-your-qwen-key-here

# Optional: DeepSeek API Key — enables dual-model regret score audit
# Without this, classification uses Qwen only (still works great)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
